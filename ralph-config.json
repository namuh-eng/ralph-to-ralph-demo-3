{
  "targetUrl": "https://mintlify.com",
  "targetName": "namuh-mintlify",
  "cloudProvider": "aws",
  "deploymentTier": "team",
  "framework": "nextjs",
  "database": "postgres",
  "dbProvider": "neon",
  "skipDeploy": false,
  "authMode": "better-auth",
  "browserAgent": "ever",
  "testAccount": {
    "provider": "google"
  },
  "services": {
    "storage": { "provider": "s3", "package": "@aws-sdk/client-s3" },
    "containerRegistry": { "provider": "ecr" }
  },
  "sdk": {
    "enabled": true,
    "languages": ["typescript"]
  },
  "research": {
    "apiEndpoints": [
      "POST /api/projects - create documentation project",
      "GET /api/projects/:id - get project details",
      "PUT /api/projects/:id - update project settings",
      "POST /api/projects/:id/deploy - trigger deployment",
      "GET /api/projects/:id/analytics - get page view analytics",
      "POST /api/search - AI-powered doc search",
      "POST /api/chat - conversational AI assistant",
      "GET /api/orgs/:id/members - list team members",
      "POST /api/orgs/:id/members - invite team member",
      "DELETE /api/orgs/:id/members/:userId - remove member"
    ],
    "authPattern": "OAuth (Google) via Better Auth, session-based",
    "dataModel": "orgs -> projects -> pages (MDX content), users -> org memberships, search indexes, analytics events, AI conversations",
    "summary": "Mintlify is an AI-native documentation platform. Users create orgs, connect GitHub repos, write docs in MDX with built-in components (callouts, cards, tabs, code blocks, API playground), configure navigation/theming/branding, deploy to custom domains, and get AI-powered search and chat. Features: MDX editor with live preview, component library, git-based workflows, OpenAPI auto-docs, analytics dashboard, team management with RBAC, MCP server generation, multi-tenant hosting."
  },
  "setup": {
    "verified": ["node", "aws-cli", "ever-cli", "neon", "anthropic-api-key", "google-oauth"],
    "pending": [],
    "checks": {
      "node": { "command": "node -v", "status": "pass", "detail": "v22.18.0" },
      "aws-cli": { "command": "aws sts get-caller-identity", "status": "pass", "detail": "account 699486076867, user ashley-dev" },
      "ever-cli": { "command": "ever --version", "status": "pass", "detail": "v0.1.0" },
      "neon": { "envVar": "DATABASE_URL", "status": "pass", "detail": "Neon connection string configured" },
      "anthropic-api-key": { "envVar": "ANTHROPIC_API_KEY", "status": "pass", "detail": "Key configured" },
      "google-oauth": { "envVar": "AUTH_GOOGLE_ID", "status": "pass", "detail": "Keys found. Redirect URI + consent screen: user confirmed." }
    }
  }
}
