# Ralph-to-Ralph Environment Variables
# Copy this to .env and fill in your values

# ── AWS (optional but recommended for real infrastructure) ──
# AWS CLI should be configured via: aws configure
# Or set these explicitly:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Database (set by scripts/preflight.sh) ──
# DATABASE_URL=postgresql://postgres:yourpassword@your-rds-endpoint:5432/your-db

# ── Cloudflare DNS (optional — enables auto-configure for domain verification) ──
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ── Dashboard Auth (optional — protects the deployed dashboard) ──
# DASHBOARD_KEY=your-secret-key

# ── Target Product (optional — for testing/comparing behavior) ──
# RESEND_API_KEY=re_xxxxx
